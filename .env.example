# ============================================================================
# AcadClarifier Docker Environment Configuration
# ============================================================================
# Copy this file to .env and adjust values for your environment
# Do NOT commit .env with real secrets to version control!
# ============================================================================

# Database Configuration
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=acadclarifier
DB_PORT=5432

# Flask Configuration
FLASK_ENV=production
FLASK_APP=wsgi:app

# Port Configuration
BACKEND_PORT=5000
FRONTEND_PORT=8501

# Application Paths
BOOK_RECOMMENDER_CHROMA_PATH=/app/services/book-recommender/chroma_data

# External API Keys (optional - only if using web retrieval or Google AI)
GOOGLE_API_KEY=your_google_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================================================
# Notes:
# - For production, use strong passwords
# - Store API keys securely (consider using secrets manager)
# - Update DB_PASSWORD before deploying
# ============================================================================
