{
  "name": "acadclarifier-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  // GitHub mounts the repo to /workspaces/RepoName. 
  // We point to that, or the specific subfolder if you want VS Code to open directly inside it.
  "workspaceFolder": "/workspaces/Acadclarifier",
  
  "forwardPorts": [8888],
  
  // Since we installed requirements in the Dockerfile, we don't strictly need this.
  // But if you want to ensure it runs, we must cd into the directory first.
  "postCreateCommand": "cd to-vector && pip install -r requirements.txt",
  
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens"
      ]
    }
  }
}
